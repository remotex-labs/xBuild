{
    "compilerOptions": {
        "strict": true,
        "target": "ESNext",
        "module": "ESNext",
        "baseUrl": "src",
        "rootDir": ".",
        "outDir": "dist",
        "declaration": true,
        "skipLibCheck": true,
        "importHelpers": true,
        "isolatedModules": false,
        "esModuleInterop": false,
        "moduleDetection": "force",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "allowSyntheticDefaultImports": true,
        "forceConsistentCasingInFileNames": true,
        "lib": [
            "DOM",
            "ESNext"
        ],
        "types": [
            "node"
        ],
        "paths": {
            "@services/*": [
                "services/*"
            ],
            "@symlinks/*": [
                "modules/symlinks/*"
            ],
            "@observable/*": [
                "modules/observable/*"
            ],
            "@typescript/*": [
                "modules/typescript/*"
            ]
        }
    },
    "include": [
        "src/bash.ts",
        "src/index.ts",
        "includes/**/*.d.ts"
    ],
    "exclude": [
        "dist",
        "node_modules",
        "**/*.spec.ts"
    ]
}
