{
    "compilerOptions": {
        "strict": true,
        "target": "ESNext",
        "module": "ESNext",
        "outDir": "dist",
        "rootDir": "src",
        "composite": false,
        "declaration": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "isolatedModules": true,
        "moduleDetection": "force",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "emitDeclarationOnly": true,
        "lib": [
            "DOM",
            "ESNext"
        ],
        "types": [
            "node"
        ],
        "paths": {
            "@modules/*": [
                "./src/modules/*"
            ],
            "@services/*": [
                "./src/services/*"
            ],
            "@interfaces/*": [
                "./src/interfaces/*"
            ],
            "@components/*": [
                "./src/components/*"
            ],
            "@observable/*": [
                "./src/modules/observable/*"
            ],
            "@typescript/*": [
                "./src/modules/typescript/*"
            ]
        }
    },
    "include": [
        "src/bash.ts",
        "src/index.ts",
        "includes/**/*.d.ts"
    ],
    "exclude": [
        "dist",
        "node_modules",
        "**/*.spec.ts"
    ],
    "references": [
        { "path": "./tsconfig.spec.json" }
    ]
}
