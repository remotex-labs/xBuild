{
    "name": "@remotex-labs/xbuild",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "author": "Garefild",
    "version": "1.0.0-local",
    "license": "Mozilla Public License Version 2.0",
    "description": "A versatile JavaScript and TypeScript toolchain build system",
    "homepage": "https://github.com/remotex-labs/xBuild",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/remotex-labs/xBuild.git"
    },
    "bugs": {
        "url": "https://github.com/remotex-labs/xBuild/issues"
    },
    "keywords": [
        "xbuild",
        "xBuild",
        "esbuild",
        "typescript",
        "restart",
        "reload",
        "monitor",
        "watch",
        "cli",
        "runtime",
        "node",
        "cjs",
        "commonjs",
        "esm",
        "typescript runner"
    ],
    "engines": {
        "node": ">=22"
    },
    "files": [
        "man",
        "dist",
        "certs",
        "LICENSE",
        "README.md"
    ],
    "bin": {
        "xbuild": "dist/bash.js",
        "xBuild": "dist/bash.js"
    },
    "scripts": {
        "dev":              "xBuild -w",
        "build":            "xBuild",
        "build:clean":      "rm -rf ./dist && xBuild",

        "test":             "xjet",
        "test:coverage":    "xjet --coverage",

        "lint":             "pnpm lint:md && pnpm lint:eslint && pnpm lint:typescript",
        "lint:md":          "markdownlint \"**/*.md\" --ignore node_modules",
        "lint:eslint":      "eslint . -c ./eslint.config.mjs",
        "lint:typescript":  "xBuild --tc",

        "docs:dev":         "vitepress dev docs",
        "docs:build":       "vitepress build docs",
        "docs:preview":     "vitepress preview docs",

        "ci":              "pnpm lint && pnpm test && pnpm build:clean",
        "prepublishOnly":  "pnpm lint && pnpm test && pnpm build:clean"
    },
    "devDependencies": {
        "eslint": "^10.3.0",
        "vitepress": "^2.0.0-alpha.15",
        "markdownlint-cli": "^0.48.0",
        "typescript-eslint": "^8.59.3",
        "eslint-plugin-tsdoc": "^0.5.2",
        "eslint-plugin-perfectionist": "^5.9.0",
        "@types/node": "^25.7.0",
        "@remotex-labs/xjet": "^1.5.4",
        "@viteplus/versions": "^2.0.6",
        "@remotex-labs/xbuild": "^2.4.1"
    },
    "dependencies": {
        "yargs": "^18.0.0",
        "esbuild": "^0.28.0",
        "typescript": "^6.0.3",
        "@types/yargs": "^17.0.35",
        "@remotex-labs/xmap": "^5.1.0",
        "@remotex-labs/xansi": "^1.3.7"
    }
}
